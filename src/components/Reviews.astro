---
import { getI18n } from '../i18n/ui';
import { siteConfig } from '../config';

const { messages } = getI18n(Astro.url);
const r = messages.reviews;
const reviews = r.reviews;

function stars(n: number) {
  let out = '';
  for (let i = 1; i <= 5; i++) {
    out += `<span class="${i <= n ? 'star-filled' : 'star-empty'}">★</span>`;
  }
  return out;
}
---

<section id="reviews" class="section-padding" style="background: var(--bg-tertiary);">
  <div class="max-w-5xl mx-auto px-4">
    <h2 class="section-title">{r.title}</h2>
    <p class="section-subtitle">{r.subtitle}</p>

    <div class="flex items-center justify-center gap-2 mb-8">
      <span class="text-2xl font-bold" style="color: var(--accent);">4.0</span>
      <span class="text-lg" set:html={stars(4)}></span>
      <span class="text-sm" style="color: var(--text-secondary);">{r.ratingSummary}</span>
    </div>

    <div class="grid sm:grid-cols-2 gap-4">
      {reviews.map((rev: any) => (
        <div class="card">
          <div class="flex items-center justify-between mb-2">
            <span class="font-semibold" style="color: var(--text-primary);">{rev.name}</span>
            <span class="text-lg" set:html={stars(rev.rating)}></span>
          </div>
          <p class="text-sm leading-relaxed m-0" style="color: var(--text-secondary);">{rev.text}</p>
        </div>
      ))}
    </div>

    <div class="text-center mt-8">
      <!-- MAP LINK #3 (Reviews) -->
      <a class="btn-cta btn-cta-primary" href={siteConfig.mapsUrl} target="_blank" rel="noopener noreferrer">
        📍 {r.viewLocation}
      </a>
    </div>
  </div>
</section>
