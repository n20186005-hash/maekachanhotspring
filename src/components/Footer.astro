---
import { getI18n } from '../i18n/ui';
import { siteConfig } from '../config';

const { lang, messages } = getI18n(Astro.url);
const f = messages.footer;

const navLinks = [
  { href: `/${lang}`, label: f.home },
  { href: `/${lang}#overview`, label: f.visit },
  { href: `/${lang}#gallery`, label: f.gallery },
  { href: `/${lang}#reviews`, label: f.reviews },
  { href: `/${lang}#map`, label: f.map },
];
---

<footer class="section-padding" style="background: var(--bg-tertiary); border-top: 1px solid var(--border-color);">
  <div class="max-w-6xl mx-auto px-4">
    <div class="mission-block mb-10">
      <h3 class="mission-title">📍 {f.siteName}</h3>
      <p class="mission-text">{f.tagline}</p>
    </div>

    <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-10">
      <div>
        <h4 class="font-semibold mb-3" style="color: var(--text-primary);">{f.navTitle}</h4>
        <ul class="space-y-2 text-sm">
          {navLinks.map((n) => (
            <li><a href={n.href} class="hover:opacity-70" style="color: var(--text-secondary);">{n.label}</a></li>
          ))}
        </ul>
      </div>

      <div>
        <h4 class="font-semibold mb-3" style="color: var(--text-primary);">{f.googleMapsLabel}</h4>
        <!-- MAP LINK #4 (Footer) -->
        <a class="footer-maps-link" href={siteConfig.mapsUrl} target="_blank" rel="noopener noreferrer">
          {f.googleMapsLabel} →
        </a>
      </div>

      <div>
        <h4 class="font-semibold mb-3" style="color: var(--text-primary);">{messages.common.googleMaps}</h4>
        <p class="text-sm leading-relaxed" style="color: var(--text-secondary);">{messages.overview.addressValue}</p>
      </div>
    </div>

    <div class="mt-10 pt-6 border-t text-xs" style="border-color: var(--border-color); color: var(--text-muted);">
      <p class="leading-relaxed">{f.copyright}</p>
      <p class="mt-3 leading-relaxed">{f.disclaimer}</p>
    </div>
  </div>
</footer>
