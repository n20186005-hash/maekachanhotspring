---
import { getI18n } from '../i18n/ui';

const { messages } = getI18n(Astro.url);
const m = messages.map;
const address = messages.overview.addressValue;
const embedSrc = `https://www.google.com/maps?q=${encodeURIComponent(address)}&output=embed`;
---

<section id="map" class="section-padding" style="background: var(--bg-primary);">
  <div class="max-w-6xl mx-auto px-4">
    <h2 class="section-title">{m.title}</h2>
    <p class="section-subtitle">{m.subtitle}</p>

    <div class="map-container rounded-2xl overflow-hidden border" style="border-color: var(--map-border); box-shadow: var(--card-shadow);">
      <iframe
        src={embedSrc}
        width="100%"
        height="420"
        style="border:0;"
        loading="lazy"
        referrerpolicy="no-referrer-when-downgrade"
        title={m.embedTitle}
        allowfullscreen
      ></iframe>
    </div>

    <p class="text-center text-sm mt-4" style="color: var(--text-muted);">{m.note}</p>
  </div>
</section>
