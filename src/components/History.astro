---
import { getI18n } from '../i18n/ui';

const { messages } = getI18n(Astro.url);
const h = messages.history;
---

<section id="history" class="section-padding" style="background: var(--bg-primary);">
  <div class="max-w-4xl mx-auto px-4">
    <h2 class="section-title">{h.title}</h2>
    <p class="section-subtitle">{h.subtitle}</p>

    <div class="grid md:grid-cols-2 gap-8 mt-12">
      <div class="card" style="background: var(--bg-secondary);">
        <div class="flex items-center gap-3 mb-4">
          <span class="text-2xl">🌋</span>
          <h3 class="font-display text-xl font-semibold m-0" style="color: var(--text-primary);">{h.geoTitle}</h3>
        </div>
        <p class="text-[0.95rem] leading-[1.8] m-0" style="color: var(--text-secondary);">
          {h.geoText}
        </p>
      </div>

      <div class="card" style="background: var(--bg-secondary);">
        <div class="flex items-center gap-3 mb-4">
          <span class="text-2xl">📜</span>
          <h3 class="font-display text-xl font-semibold m-0" style="color: var(--text-primary);">{h.legendTitle}</h3>
        </div>
        <p class="text-[0.95rem] leading-[1.8] m-0" style="color: var(--text-secondary);">
          {h.legendText}
        </p>
      </div>
    </div>
  </div>
</section>